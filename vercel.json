{
  "redirects": [
    { "source": "/tienda", "destination": "/", "permanent": true },
    { "source": "/tienda/", "destination": "/", "permanent": true },
    { "source": "/descarga", "destination": "/app/descarga", "permanent": true },
    { "source": "/descarga/", "destination": "/app/descarga", "permanent": true }
  ],
  "rewrites": [
    { "source": "/app/descarga", "destination": "/descarga.html" },
    { "source": "/app/descarga/", "destination": "/descarga.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/app/", "destination": "/app.html" },
    { "source": "/app/(.*)", "destination": "/app.html" },
    { "source": "/seguimiento", "destination": "/seguimiento/index.html" },
    { "source": "/seguimiento/", "destination": "/seguimiento/index.html" },
    { "source": "/cuenta", "destination": "/tienda/index.html" },
    { "source": "/cuenta/", "destination": "/tienda/index.html" },
    { "source": "/(.*)", "destination": "/tienda/index.html" }
  ]
}

