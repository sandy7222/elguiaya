{
  "redirects": [
    { "source": "/descarga{/}?", "destination": "/api/track-download?source=direct_url", "permanent": false }
  ],
  "rewrites": [
    { "source": "/tienda", "destination": "/tienda/index.html" },
    { "source": "/tienda/", "destination": "/tienda/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
